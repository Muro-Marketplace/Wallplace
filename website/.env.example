# ─── Wallplace environment template ─────────────────────────────────
# Copy to `.env.local` for dev, or set these in the Vercel project.
# Prefixing with NEXT_PUBLIC_ exposes the value to the browser.
# Everything else is server-only.
#
# The schema in src/env.ts validates these at boot — missing required
# vars fail loudly on first load instead of silently at request time.

# ─── Supabase (REQUIRED) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."
# Service-role key bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://wallplace.co.uk"

# ─── Admin (REQUIRED for admin access) ───────────────────────────────
# Comma-separated list of admin email addresses. Fails CLOSED if unset.
ADMIN_EMAILS="you@wallplace.co.uk"

# ─── Cron (REQUIRED for scheduled routes + payout processing) ────────
# Any random 32-char string. Vercel Cron attaches this as a Bearer token.
CRON_SECRET=""

# ─── Stripe (REQUIRED for payments) ──────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_CORE=""
STRIPE_PRICE_CORE_ANNUAL=""
STRIPE_PRICE_PREMIUM=""
STRIPE_PRICE_PREMIUM_ANNUAL=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_PRO_ANNUAL=""

# ─── Resend (OPTIONAL — email sending) ───────────────────────────────
# Without this, sendEmail() short-circuits with `skipped: no_api_key`.
RESEND_API_KEY=""
# Sender domains per stream. Until notify./news. are verified, point all
# three at the verified tx. subdomain.
EMAIL_FROM_TX="Wallplace <noreply@tx.wallplace.co.uk>"
EMAIL_FROM_NOTIFY="Wallplace <notifications@tx.wallplace.co.uk>"
EMAIL_FROM_NEWS="Wallplace <hello@tx.wallplace.co.uk>"
EMAIL_REPLY_TO="hello@wallplace.co.uk"
